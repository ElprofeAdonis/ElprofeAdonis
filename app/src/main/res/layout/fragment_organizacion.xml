<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".activity.ui.organizacion.OrganizacionFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="40dp"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="Salón Virtual"
            android:textSize="20dp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:background="@color/black"
            android:layout_margin="5dp"
            android:layout_height="1dp"/>

        <TextView
            android:layout_width="match_parent"
            android:text="Notificaciones que desees recibir"
            android:layout_height="wrap_content" />
        <TextView
            android:layout_width="match_parent"
            android:text=""
            android:layout_height="wrap_content" />


        <Switch
            android:id="@+id/citas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Citas" />

        <Switch
            android:id="@+id/educacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="5dp"
            android:text="Reuniones programadas" />

        <Switch
            android:id="@+id/consultas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="5dp"
            android:text="Consultas" />

        <Switch
            android:id="@+id/calificar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="5dp"
            android:text="Por calificar" />

        <Switch
            android:id="@+id/conferencias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Videoconferencias" />

        <Switch
            android:id="@+id/eventos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Eventos" />

        <Switch
            android:id="@+id/tutorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Centro de tutorías" />

        <Switch
            android:id="@+id/Entrevistas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Entrevistas" />
        <Switch
            android:id="@+id/alhogar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Informe al hogar" />
        <Switch
            android:id="@+id/Entretiminetos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Actividades recreativas" />
        <Switch
            android:id="@+id/Evento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Eventos para padres" />
        <Switch
            android:id="@+id/Horario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_gravity="center_horizontal"
            android:text="Horario de clases" />

        <View
            android:layout_width="match_parent"
            android:background="@color/black"
            android:layout_margin="5dp"
            android:layout_height="1dp"/>

        <TextView
            android:layout_width="match_parent"
            android:text=""
            android:layout_height="wrap_content" />

    </LinearLayout>

</RelativeLayout>